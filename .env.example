# Folder Syncthing fills with PDFs manually exported from Notein.
NOTEIN_WATCH_DIR=/home/user/notein_backup/pdfs

# Notion: https://www.notion.so/my-integrations -> Internal Integration Secret.
# The integration needs access to the target database via "Connections".
NOTION_TOKEN=

# The single database every note is uploaded to. DATABASE_ID is the part of the
# Notion URL before "?v=".
NOTION_DATABASE_ID=

# Optional: names of the Title, Files & media, and Kurs (course) properties in your
# Notion database, if you renamed them from the defaults below.
NOTION_TITLE_PROPERTY=Name
NOTION_FILE_PROPERTY="Files & media"
NOTION_COURSE_PROPERTY=Kurs

# Optional: also set a Status select property on every imported note (e.g. to mark
# it as needing review). Both must be set together, or neither.
#NOTION_STATUS_PROPERTY=Status
#NOTION_STATUS_VALUE=Entwurf

# One line per subject. The part after NOTEIN_COURSE_ must match the filename prefix
# before the first underscore, e.g. MATHE1_Test1.pdf -> NOTEIN_COURSE_MATHE1. The
# value must match an existing "Kurs" select option exactly, otherwise Notion
# silently creates a new (randomly colored) option instead of reusing one.
#
# Don't write these by hand: run `cargo run -- configure` instead. It fetches your
# Kurs options from Notion, suggests a prefix per course (and guarantees no two
# collide), lets you review/edit each one in a TUI, and writes this block for you.
# It also drops a plain-text prefix -> course name reference into NOTEIN_WATCH_DIR,
# which syncs to your phone the same way the PDFs do, so you never have to
# memorize the abbreviations to name a file correctly.
NOTEIN_COURSE_MATHE1="Mathematik I"
NOTEIN_COURSE_TI1="Theoretische Informatik I"

# Optional: seconds between scans of the watch folder (default: 60).
SYNC_INTERVAL_SECS=60
