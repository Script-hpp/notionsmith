# Folder Syncthing fills with PDFs manually exported from Notein.
NOTEIN_WATCH_DIR=/home/user/notein_backup/pdfs

# Notion: https://www.notion.so/my-integrations -> Internal Integration Secret.
# The integration needs access to every database listed below via "Connections".
NOTION_TOKEN=

# Optional: names of the Title and Files & media properties in your Notion databases,
# if you renamed them from Notion's defaults.
NOTION_TITLE_PROPERTY=Name
NOTION_FILE_PROPERTY="Files & media"

# One line per subject. The part after NOTEIN_DB_ must match the filename prefix
# before the first underscore, e.g. MATHE1_Test1.pdf -> NOTEIN_DB_MATHE1.
# DATABASE_ID is the part of the Notion URL before "?v=".
NOTEIN_DB_MATHE1=
NOTEIN_DB_PHYSIK2=

# Optional: seconds between scans of the watch folder (default: 60).
SYNC_INTERVAL_SECS=60
